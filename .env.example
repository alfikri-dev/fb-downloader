# Environment configuration for fb-downloader

# Server
PORT=3000

# Output directory (tempat simpan file download)
FB_DL_OUTPUT_DIR=/tmp/fb_downloads

# yt-dlp timeout dalam milliseconds (default 120000 = 2 menit)
FB_DL_TIMEOUT_MS=120000

# Path ke yt-dlp binary (opsional, auto-detect kalau tidak diset)
# YTDLP_BIN=/root/.hermes/hermes-agent/venv/bin/yt-dlp
